# VN Stock Trader — Environment Variables
# Copy this file to .env and fill in your values

# ─── Data Sources ────────────────────────────────────────────────
# vnstock dùng TCBS/VCI làm nguồn mặc định, không cần API key
# nhưng nếu có account SSI/TCBS thì điền vào đây để có rate limit cao hơn

# SSI (tùy chọn)
SSI_USERNAME=
SSI_PASSWORD=
SSI_ACCOUNT_NO=

# TCBS (tùy chọn)
TCBS_TOKEN=

# VNDirect (tùy chọn)
VNDIRECT_USERNAME=
VNDIRECT_PASSWORD=

# ─── Cache ───────────────────────────────────────────────────────
CACHE_DB_PATH=mcp-server/cache/vn_stock.db

# ─── Portfolio ───────────────────────────────────────────────────
PORTFOLIO_PATH=data/portfolio.json
WATCHLIST_PATH=data/watchlist.json

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# ─── Rate Limiting ───────────────────────────────────────────────
REQUEST_DELAY_MIN=1.0   # giây
REQUEST_DELAY_MAX=2.5   # giây
